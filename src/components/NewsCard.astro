---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;
const base = import.meta.env.BASE_URL;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`${base}news/${slug}/`} class="news-card">
  <time class="news-date" datetime={date.toISOString()}>{formattedDate}</time>
  <h3 class="news-title">{title}</h3>
  <p class="news-desc">{description}</p>
  <span class="news-link">Read more &rarr;</span>
</a>

<style>
  .news-card {
    display: flex;
    flex-direction: column;
    background-color: var(--gu-color-white);
    border: 1px solid var(--gu-color-basalt-tint-30);
    border-radius: var(--gu-border-radius);
    padding: var(--gu-space-xl);
    text-decoration: none;
    color: var(--gu-color-text-primary);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .news-card:hover {
    border-color: var(--gu-color-river-blue);
    box-shadow: 0 4px 12px rgba(6, 39, 79, 0.1);
    text-decoration: none;
  }

  .news-date {
    font-size: var(--gu-font-size-breadcrumb);
    font-weight: var(--gu-font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gu-color-river-blue);
    margin-bottom: var(--gu-space-sm);
  }

  .news-title {
    font-size: var(--gu-font-size-h4);
    margin-bottom: var(--gu-space-sm);
    line-height: var(--gu-line-height-subheading);
  }

  .news-desc {
    font-size: var(--gu-font-size-small);
    color: var(--gu-color-text-secondary);
    line-height: var(--gu-line-height-body);
    flex-grow: 1;
  }

  .news-link {
    font-size: var(--gu-font-size-small);
    font-weight: var(--gu-font-weight-semibold);
    color: var(--gu-color-link);
    margin-top: var(--gu-space-md);
  }

  .news-card:hover .news-link {
    text-decoration: underline;
  }
</style>
