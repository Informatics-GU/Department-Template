---
import { DEPARTMENT } from "../config";

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = "Ready to Get Started?",
  text = `Learn more about what ${DEPARTMENT.name} has to offer.`,
} = Astro.props;
---

<section class="cta-section">
  <div class="container cta-inner">
    <h2 class="cta-heading">{heading}</h2>
    <p class="cta-text">{text}</p>
    <div class="cta-buttons">
      <a href={DEPARTMENT.ctas.primary.url} class="btn btn-secondary">
        {DEPARTMENT.ctas.primary.text}
      </a>
      <a href={DEPARTMENT.ctas.secondary.url} class="btn btn-outline cta-btn-outline">
        {DEPARTMENT.ctas.secondary.text}
      </a>
      <a href={DEPARTMENT.ctas.tertiary.url} class="btn btn-outline cta-btn-outline">
        {DEPARTMENT.ctas.tertiary.text}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--gu-color-blue);
    color: var(--gu-color-text-on-dark);
    padding: var(--gu-space-3xl) 0;
  }

  .cta-inner {
    text-align: center;
  }

  .cta-heading {
    color: var(--gu-color-text-on-dark);
    margin-bottom: var(--gu-space-md);
  }

  .cta-text {
    font-size: var(--gu-font-size-lead);
    color: var(--gu-color-warm-beige);
    margin-bottom: var(--gu-space-xl);
  }

  .cta-buttons {
    display: flex;
    gap: var(--gu-space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn-outline {
    color: var(--gu-color-white);
    border-color: var(--gu-color-white);
  }

  .cta-btn-outline:hover {
    background-color: var(--gu-color-white);
    color: var(--gu-color-blue);
  }
</style>
