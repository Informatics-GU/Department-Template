---
interface Props {
  title: string;
  degree: string;
  description: string;
  slug: string;
}

const { title, degree, description, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}programs/${slug}/`} class="program-card">
  <span class="program-degree">{degree}</span>
  <h3 class="program-title">{title}</h3>
  <p class="program-desc">{description}</p>
  <span class="program-link">Learn more &rarr;</span>
</a>

<style>
  .program-card {
    display: flex;
    flex-direction: column;
    background-color: var(--gu-color-white);
    border: 1px solid var(--gu-color-basalt-tint-30);
    border-radius: var(--gu-border-radius);
    padding: var(--gu-space-xl);
    text-decoration: none;
    color: var(--gu-color-text-primary);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .program-card:hover {
    border-color: var(--gu-color-river-blue);
    box-shadow: 0 4px 12px rgba(6, 39, 79, 0.1);
    text-decoration: none;
  }

  .program-degree {
    font-size: var(--gu-font-size-breadcrumb);
    font-weight: var(--gu-font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gu-color-river-blue);
    margin-bottom: var(--gu-space-sm);
  }

  .program-title {
    font-size: var(--gu-font-size-h3);
    margin-bottom: var(--gu-space-sm);
  }

  .program-desc {
    font-size: var(--gu-font-size-small);
    color: var(--gu-color-text-secondary);
    line-height: var(--gu-line-height-body);
    flex-grow: 1;
  }

  .program-link {
    font-size: var(--gu-font-size-small);
    font-weight: var(--gu-font-weight-semibold);
    color: var(--gu-color-link);
    margin-top: var(--gu-space-md);
  }

  .program-card:hover .program-link {
    text-decoration: underline;
  }
</style>
