---
interface Props {
  name: string;
  title: string;
  email?: string;
  phone?: string;
  slug: string;
}

const { name, title, email, phone, slug } = Astro.props;

const initials = name
  .split(" ")
  .map((n) => n[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("");
---

<div class="faculty-card">
  <a href={`/faculty/${slug}/`} class="faculty-avatar" aria-hidden="true">
    <span class="faculty-initials">{initials}</span>
  </a>
  <div class="faculty-info">
    <h3 class="faculty-name">
      <a href={`/faculty/${slug}/`}>{name}</a>
    </h3>
    <p class="faculty-title">{title}</p>
    {email && (
      <a href={`mailto:${email}`} class="faculty-contact">{email}</a>
    )}
    {phone && (
      <a href={`tel:${phone}`} class="faculty-contact">{phone}</a>
    )}
  </div>
</div>

<style>
  .faculty-card {
    display: flex;
    gap: var(--gu-space-lg);
    align-items: flex-start;
    padding: var(--gu-space-lg);
    background-color: var(--gu-color-white);
    border: 1px solid var(--gu-color-basalt-tint-30);
    border-radius: var(--gu-border-radius);
  }

  .faculty-avatar {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background-color: var(--gu-color-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .faculty-initials {
    color: var(--gu-color-white);
    font-family: var(--gu-font-serif);
    font-size: var(--gu-font-size-h3);
    font-weight: var(--gu-font-weight-bold);
  }

  .faculty-info {
    min-width: 0;
  }

  .faculty-name {
    font-size: var(--gu-font-size-h4);
    margin-bottom: var(--gu-space-xs);
  }

  .faculty-name a {
    color: var(--gu-color-text-primary);
    text-decoration: none;
  }

  .faculty-name a:hover {
    color: var(--gu-color-link);
    text-decoration: underline;
  }

  .faculty-title {
    font-size: var(--gu-font-size-small);
    color: var(--gu-color-text-secondary);
    margin-bottom: var(--gu-space-sm);
  }

  .faculty-contact {
    display: block;
    font-size: var(--gu-font-size-caption);
    color: var(--gu-color-link);
    margin-bottom: var(--gu-space-xs);
  }
</style>
